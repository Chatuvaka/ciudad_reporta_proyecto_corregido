{
  "version": 2,
  "installCommand": "npm install && npm install --prefix frontend && npm install --prefix backend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/reportes/trabajador/:id/tomar", "destination": "/api/reportes/trabajador/tomar?id=:id" },
    { "source": "/api/reportes/trabajador/:id/completar", "destination": "/api/reportes/trabajador/completar?id=:id" },
    { "source": "/api/reportes/trabajador/:id/cancelar", "destination": "/api/reportes/trabajador/cancelar?id=:id" },
    { "source": "/api/reportes/trabajador/:id", "destination": "/api/reportes/trabajador/detalle?id=:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
