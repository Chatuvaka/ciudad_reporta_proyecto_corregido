{
  "version": 2,
  "installCommand": "npm install && npm install --prefix ../backend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "(.*)",
      "destination": "/index.html"
    }
  ]
}
